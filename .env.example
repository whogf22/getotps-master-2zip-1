# Server Configuration
NODE_ENV=development
PORT=5000

# Session Secret (REQUIRED in production - use a strong random string min 64 chars)
SESSION_SECRET=your-session-secret-here

# Admin Seed Credentials (REQUIRED in production)
ADMIN_EMAIL=admin@getotps.online
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_USERNAME=admin

# Proxnum SMS Provider API Key
PROXNUM_API_KEY=your-proxnum-api-key-here

# Crypto Wallet Addresses
CRYPTO_WALLET_BTC=your-btc-wallet-address
CRYPTO_WALLET_ETH=your-eth-wallet-address
CRYPTO_WALLET_USDT_TRC20=your-usdt-trc20-wallet-address
CRYPTO_WALLET_USDT_ERC20=your-usdt-erc20-wallet-address
CRYPTO_WALLET_USDC=your-usdc-wallet-address
CRYPTO_WALLET_LTC=your-ltc-wallet-address

# Crypto Rates (USD per coin, update regularly)
CRYPTO_RATE_BTC=84250.00
CRYPTO_RATE_ETH=3420.00
CRYPTO_RATE_USDT=1.00
CRYPTO_RATE_USDC=1.00
CRYPTO_RATE_LTC=92.50

# Database (SQLite - auto-created)
# DATABASE_URL=./data.db
