# Required
PROXNUM_API_KEY=your_proxnum_api_key_here
SESSION_SECRET=generate_a_random_32char_string_here

# Optional - Circle USDC Integration
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_32_byte_entity_secret_here

# Optional - Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_here

# Optional - App URL (for password reset links)
APP_URL=https://your-app-url.replit.app

# Optional - Manual Crypto Deposit Wallet Addresses
WALLET_BTC=your_btc_address
WALLET_ETH=your_eth_address
WALLET_USDT_TRC20=your_trc20_address
WALLET_USDT_ERC20=your_erc20_address
WALLET_USDC=your_usdc_address
WALLET_LTC=your_ltc_address

# Set by Replit automatically
PORT=5000
NODE_ENV=production
